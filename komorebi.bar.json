{
    "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.41/schema.bar.json",
    "font_family": "UDEV Gothic 35NFLG",
    "font_size": 13.0,
    "theme": {
        "palette": "Base16",
        "name": "Ashes",
        "accent": "Base0D"
    },
    "left_widgets": [
        {
            "Komorebi": {
                "layout": {
                    "enable": true,
                    "display": "Icon"
                },
                "workspaces": {
                    "enable": true,
                    "hide_empty_workspaces": false,
                    "display": "AllIconsAndText"
                }
            }
        }
    ],
    "center_widgets": [
        {
            "Komorebi": {
                "focused_container": {
                    "enable": true,
                    "display": "IconAndText"
                }
            }
        }
    ],
    "right_widgets": [
        {
            "Keyboard": {
                "enable": true
            }
        },
        {
            "Systray": {
                "enable": true,
                "info_button": "Overflow",
                "overflow_toggle_position": "Right",
                "refresh_button": "Overflow",
                "shortcuts_button": null
            }
        },
        {
            "Update": {
                "enable": true
            }
        },
        {
            "Date": {
                "enable": true,
                "format": "YearMonthDate"
            }
        },
        {
            "Time": {
                "enable": true,
                "format": "TwentyFourHourWithoutSeconds"
            }
        }
    ]
}
