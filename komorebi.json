{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.41/schema.json",
  "animation": {
      "enabled": false
  },
  "app_specific_configuration_path": "$Env:USERPROFILE/applications.json",
  "border": true,
  "border_width": 8,
  "border_offset": -2,
  "border_style": "Square",
  "cross_monitor_move_behaviour": "Insert",
  "default_container_padding": -2,
  "default_workspace_padding": -2,
  "floating_layer_placement": "CenterAndResize",
  "floating_window_aspect_ratio": "Widescreen",
  "ignore_rules": [
    {
      "kind": "Exe",
      "id": "A5M2.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "i_view64.exe",
      "matching_strategy": "Equals"
    }
  ],
  "monitors": [
    {
      "workspaces": [
        {
          "name": " M1",
          "layout": "UltrawideVerticalStack"
        },
        {
          "name": " D2",
          "layout": "Scrolling"
        },
        {
          "name": " E3 ",
          "layout": "BSP"
        },
        {
          "name": " E4 ",
          "layout": "BSP"
        }
      ]
    }
  ],
  "mouse_follows_focus": true,
  "stackbar": {
    "height": 30,
    "mode": "OnStack",
    "tabs": {
      "width": 300,
      "focused_text": "#9999ff",
      "unfocused_text": "#aaaaaa",
      "background": "#222222"
    },
    "label": "Title"
  },
  "transparency": true,
  "transparency_alpha": 220,
  "window_hiding_behaviour": "Cloak"
}
